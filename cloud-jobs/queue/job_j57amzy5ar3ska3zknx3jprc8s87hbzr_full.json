      "emotion": "happy",
      "endTime": 20.790940766550523,
      "environment": "A path leading away from the village toward a lush green forest.",
      "narrationText": "हड्डी को मुँह में दबाकर वह जंगल की ओर दौड़ पड़ा।",
      "sceneIndex": 2,
      "startTime": 14.926829268292684,
      "visualPrompt": "Sheru running through a field toward the woods, bone in mouth, ears flapping."
    },
    {
      "action": "Sheru stops in the middle of the bridge and leans over the edge to look at the water.",
      "beatTitle": "The Wooden Bridge",
      "characters": [
        "Sheru"
      ],
      "duration": 10.662020905923345,
      "emotion": "thinking",
      "endTime": 31.45296167247387,
      "environment": "A rustic wooden bridge over a clear blue river.",
      "narrationText": "जब शेरू पुल के बीच पहुँचा, तो उसने नीचे पानी में झाँका। उसे पानी में अपनी ही परछाई दिखाई दी।",
      "sceneIndex": 3,
      "startTime": 20.790940766550523,
      "visualPrompt": "Sheru looking down from a wooden bridge, seeing his own reflection in the water below."
    },
    {
      "action": "The reflection shows a dog with a bone; Sheru tilts his head, confused and intrigued.",
      "beatTitle": "The Mistaken Identity",
      "characters": [
        "Sheru"
      ],
      "duration": 9.595818815331011,
      "emotion": "suspense",
      "endTime": 41.048780487804876,
      "environment": "The surface of the river reflecting Sheru.",
      "narrationText": "शेरू को लगा कि पानी में कोई दूसरा कुत्ता है और उसके पास भी एक बड़ी हड्डी है।",
      "sceneIndex": 4,
      "startTime": 31.45296167247387,
      "visualPrompt": "POV shot of the water reflection, showing a dog looking back with a bone."
    },
    {
      "action": "Sheru's expression turns from curiosity to greed, narrowing his eyes as he thinks.",
      "beatTitle": "Greedy Ambition",
      "characters": [
        "Sheru"
      ],
      "duration": 11.728222996515681,
      "emotion": "angry",
      "endTime": 52.77700348432056,
      "environment": "On the wooden bridge.",
      "narrationText": "लालची शेरू ने सोचा कि क्यों न मैं उस कुत्ते की हड्डी भी छीन लूँ, फिर मेरे पास दो हड्डियाँ हो जाएँगी।",
      "sceneIndex": 5,
      "startTime": 41.048780487804876,
      "visualPrompt": "Sheru looking mean and greedy, imagining himself with two bones."
    },
    {
      "action": "Sheru opens his mouth to bark 'Woof!', and the bone falls toward the water.",
      "beatTitle": "The Big Mistake",
      "characters": [
        "Sheru"
      ],
      "duration": 11.728222996515681,
      "emotion": "scared",
      "endTime": 64.50522648083624,
      "environment": "On the bridge over the splashing river.",
      "narrationText": "जैसे ही उसने भौंकने के लिए अपना मुँह खोला, उसके मुँह से हड्डी फिसलकर सीधे नदी के गहरे पानी में गिर गई।",
      "sceneIndex": 6,
      "startTime": 52.77700348432056,
      "visualPrompt": "Action shot of the bone falling from Sheru's open mouth into the river."
    },
    {
