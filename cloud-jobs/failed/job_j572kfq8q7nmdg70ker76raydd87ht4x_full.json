      "characters": [
        "Jungle Animals"
      ],
      "duration": 13.334693877551022,
      "emotion": "scared",
      "endTime": 27.93935860058309,
      "environment": "A clearing in the forest where animals are huddled together",
      "narrationText": "जंगल के सभी जानवर उससे बहुत डरते थे। एक दिन, सभी जानवरों ने मिलकर शेर से बात करने का फैसला किया।",
      "sceneIndex": 1,
      "startTime": 14.604664723032071,
