    },
    {
      "action": "The animals bow before the lion; the lion looks pleased and nods his head.",
      "beatTitle": "The Agreement",
      "characters": [
        "Sher Singh",
        "Jungle Animals"
      ],
      "duration": 15.87463556851312,
      "emotion": "calm",
      "endTime": 43.81399416909621,
      "environment": "The lion's den entrance",
      "narrationText": "हम वादा करते हैं कि हर दिन आपके पास खुद एक जानवर आएगा, ताकि आपको शिकार के लिए इधर-उधर भटकना न पड़े। शेर मान गया।",
      "sceneIndex": 2,
      "startTime": 27.93935860058309,
      "visualPrompt": "Animals pleading before a sitting lion, lion looking smug and satisfied."
    },
    {
      "action": "The rabbit walking slowly, tapping his chin with a paw, looking thoughtful.",
      "beatTitle": "The Rabbit's Turn",
      "characters": [
